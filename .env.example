NODE_ENV=development
PORT=4000
# Comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# REQUIRED in production
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=12h

DATABASE_URL=
DATABASE_SSL_REQUIRE=false

# Email delivery mode: disabled | test | live
EMAIL_MODE=disabled
EMAIL_TEST_RECIPIENTS=you@example.com
ADMIN_EMAIL=admin@example.com

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@thailandpanties.local

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Security hardening:
# In production this should stay false.
ALLOW_LEGACY_PLAINTEXT_PASSWORDS=false
