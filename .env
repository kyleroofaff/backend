NODE_ENV=development
PORT=4000
# Comma-separated list is supported for multiple frontend URLs
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
JWT_SECRET=dev-local-jwt-secret-change-me-please
JWT_EXPIRES_IN=12h
DATABASE_URL=
DATABASE_SSL_REQUIRE=false

# Email delivery mode: disabled | test | live
EMAIL_MODE=disabled

# In test mode, all emails go to these recipients (comma-separated)
EMAIL_TEST_RECIPIENTS=you@example.com

ADMIN_EMAIL=you@example.com

# SMTP settings
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@thailandpanties.local
